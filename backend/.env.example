# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# MongoDB connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/mern-app?appName=Cluster0

# Server port (Vercel / Render set this automatically)
PORT=5000

# Environment: development | production
NODE_ENV=development

# Comma-separated list of allowed frontend origins (for production CORS)
# Example: https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:5173
